// Prisma schema for QLMC (projector management)
// Provider: MySQL (XAMPP)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  teacher
  technician
}

enum ProjectorStatus {
  available
  maintenance
  broken
}

enum BookingStatus {
  pending
  approved
  rejected
  completed
}

enum IssueStatus {
  reported
  in_progress
  resolved
  closed
}

enum IssuePriority {
  low
  medium
  hight
}

enum SupportRequestStatus {
  pending
  in_progress
  resolved
  closed
}

enum SupportRequestPriority {
  low
  medium
  high
  urgent
}

model User {
  id        String   @id @default(uuid())
  userID    String   @unique
  fullName  String
  email     String   @unique
  password  String
  role      Role     @default(teacher)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  avatar    String?

  bookings  Booking[]
  issues    Issue[]
  supportRequests SupportRequest[]
}

model Projector {
  id                   String          @id @default(uuid())
  name                 String
  model                String
  serialNumber         String          @unique
  room                 String
  building             String
  status               ProjectorStatus @default(available)
  purchaseDate         DateTime
  warrantyExpiry       DateTime
  timeUsed             Int             @default(0)
  lastMaintenanceDate  DateTime?
  createdAt            DateTime        @default(now())

  bookings    Booking[]
  issues      Issue[]
  supportRequests SupportRequest[]
}

model Booking {
  id          String         @id @default(uuid())
  projector   Projector      @relation(fields: [projectorId], references: [id], onDelete: Cascade)
  projectorId String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  startTime   DateTime
  endTime     DateTime
  purpose     String
  status      BookingStatus  @default(pending)
  createdAt   DateTime       @default(now())

  review      Review?

  @@index([projectorId])
  @@index([userId])
  @@index([startTime, endTime])
}

model Review {
  id          String    @id @default(uuid())
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   String    @unique
  rating      Int       // 1-5 stars
  comment     String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([bookingId])
}

model Issue {
  id          String        @id @default(uuid())
  projector   Projector     @relation(fields: [projectorId], references: [id])
  projectorId String
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  title       String
  description String?
  priority    IssuePriority  @default(medium)
  status      IssueStatus    @default(reported)
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  @@index([projectorId])
  @@index([userId])
}

model ChatbotKnowledge {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String?
  createdAt DateTime @default(now())
}

model SupportRequest {
  id          String                   @id @default(uuid())
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  projector   Projector?               @relation(fields: [projectorId], references: [id])
  projectorId String?
  title       String
  description String                   @db.Text
  priority    SupportRequestPriority   @default(medium)
  status      SupportRequestStatus     @default(pending)
  category    String?                  // e.g., "technical", "maintenance", "other"
  attachments String?                  @db.Text // JSON array of file paths
  response    String?                  @db.Text
  respondedBy String?                  // UserID of technician
  respondedAt DateTime?
  scheduledStartTime DateTime?         // Scheduled maintenance start time
  scheduledEndTime   DateTime?         // Scheduled maintenance end time
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([userId])
  @@index([projectorId])
  @@index([status])
}
